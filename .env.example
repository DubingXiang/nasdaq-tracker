# ===== 纳指估值追踪器 配置 =====
# 复制此文件为 .env，填入你自己的 key

# FRED API Key（免费申请：https://fred.stlouisfed.org/docs/api/api_key.html）
FRED_API_KEY=

# 推送通知（三选一，不填则不推送）
# PushPlus（推荐，微信扫码登录即可获取：https://www.pushplus.plus/）
PUSHPLUS_TOKEN=
# Server酱（https://sct.ftqq.com/）
SERVERCHAN_KEY=
# 企业微信机器人 Webhook URL
WECOM_WEBHOOK=
